{
  "app_name": "Aplikasi Kartu Peserta Ujian",
  "version": "Final F4",
  "html_code": "<!DOCTYPE html>\n<html lang=\"id\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Aplikasi Kartu Peserta Ujian - Versi Final F4</title>\n    \n    \n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js\"><\/script>\n\n    <style>\n        /* === CSS APLIKASI UTAMA === */\n        body { font-family: Arial, sans-serif; background-color: #f0f2f5; margin: 0; padding: 20px; }\n        .app-container { max-width: 1000px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }\n        h2 { text-align: center; color: #333; }\n        \n        /* Navigasi / Tab */\n        .tab-menu { display: flex; gap: 10px; margin-bottom: 20px; border-bottom: 2px solid #ddd; padding-bottom: 10px; }\n        .tab-btn { padding: 10px 20px; cursor: pointer; border: none; background: #eee; border-radius: 5px; font-weight: bold; }\n        .tab-btn.active { background: #4CAF50; color: white; }\n        .tab-content { display: none; }\n        .tab-content.active { display: block; }\n\n        /* Tabel Data & Form */\n        table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px;}\n        table, th, td { border: 1px solid #ddd; }\n        th, td { padding: 8px; text-align: left; }\n        th { background-color: #4CAF50; color: white; }\n        \n        /* Tombol Aksi Tabel */\n        .btn-lihat { padding: 5px; background: #2196F3; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 12px;}\n        .btn-edit { padding: 5px; background: #FFC107; color: black; border: none; border-radius: 3px; cursor: pointer; font-size: 12px;}\n        .btn-hapus { padding: 5px; background: #f44336; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 12px;}\n        \n        /* Tombol Toolbar Atas */\n        .toolbar { display: flex; gap: 10px; margin-bottom: 15px; align-items: center; justify-content: space-between; flex-wrap: wrap;}\n        .btn-toolbar { padding: 10px 15px; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }\n        .btn-tambah { background: #4CAF50; }\n        .btn-template { background: #2196F3; } \n        .btn-excel { background: #1b7339; }    \n        \n        .box-area { background: #e9f5e9; padding: 15px; border: 2px dashed #4CAF50; border-radius: 5px; margin-bottom: 15px; }\n        .form-group { margin-bottom: 15px; }\n        .form-group label { display: block; font-weight: bold; margin-bottom: 5px; }\n        .form-group input[type=\"text\"] { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }\n        .btn-simpan { padding: 10px 15px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }\n\n        /* === CSS MODAL (POP-UP FORM) === */\n        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); }\n        .modal-content { background-color: #fff; margin: 5% auto; padding: 20px; border-radius: 8px; width: 400px; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }\n        .modal-header { font-size: 18px; font-weight: bold; margin-bottom: 15px; display: flex; justify-content: space-between;}\n        .close-btn { cursor: pointer; color: red; font-weight: bold; font-size: 20px;}\n        .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }\n        .btn-batal { background: #ccc; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; }\n\n        /* === CSS KARTU PESERTA (UKURAN 10,08cm x 8,78cm) === */\n        .kartu-wrapper { display: flex; justify-content: center; padding: 20px; background: #ddd; border-radius: 5px;}\n        .kartu { width: 10.08cm; height: 8.78cm; background-color: #ffffff; border: 1px solid #000; padding: 8px 12px; box-sizing: border-box; font-family: 'Times New Roman', Times, serif; display: flex; flex-direction: column; page-break-inside: avoid; }\n        .header { display: flex; align-items: center; border-bottom: 1.5px solid #000; padding-bottom: 5px; margin-bottom: 8px; }\n        .logo { width: 45px; height: 45px; object-fit: contain; margin-right: 10px; }\n        .header-text { flex-grow: 1; text-align: center; line-height: 1.2; }\n        .header-text p { margin: 0; font-weight: bold; text-transform: uppercase; }\n        .teks-1 { font-size: 11px; } .teks-2 { font-size: 13px; } .teks-3 { font-size: 9px; } .teks-4 { font-size: 11px; }\n        .info-table { width: 100%; border-collapse: collapse; font-size: 11px; border: none; margin-bottom: 5px;}\n        .info-table td { padding: 3px 0; vertical-align: top; border: none; }\n        .info-table td:nth-child(1) { width: 85px; } .info-table td:nth-child(2) { width: 10px; text-align: center; }\n        .footer { display: flex; justify-content: space-between; align-items: flex-end; flex-grow: 1;}\n        .photo-box { width: 2.2cm; height: 3.2cm; border: 1px solid #000; display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: #f9f9f9; }\n        .photo-box img { width: 100%; height: 100%; object-fit: cover; }\n        \n        /* Modifikasi Area Tanda Tangan */\n        .signature { text-align: left; width: 130px; font-size: 10px; line-height: 1.3;}\n        .signature p { margin: 0; } \n        .ttd-box-area { height: 35px; margin: 2px 0; display: flex; align-items: center;}\n        .ttd-box-area img { max-height: 100%; max-width: 100%; object-fit: contain; display: none; }\n        .signature .name { font-weight: bold; text-decoration: underline;}\n\n        /* === AREA CETAK & KERTAS F4 === */\n        #area-cetak { display: none; }\n        \n        @page { \n            size: 215mm 330mm; /* Ukuran pas kertas F4 */\n            margin: 0mm; /* WAJIB: Nolkan margin bawaan dari printer/browser */\n        }\n        \n        @media print {\n            body * { visibility: hidden; }\n            #area-cetak, #area-cetak * { visibility: visible; }\n            \n            #area-cetak { \n                display: flex; \n                position: absolute; \n                left: 0; \n                top: 0; \n                width: 215mm; /* Paksa area cetak selebar kertas F4 */\n                box-sizing: border-box;\n                padding: 4mm 5mm; /* Jarak aman tepi kertas (Atas 4mm, Kanan-Kiri 5mm) */\n                flex-wrap: wrap; \n                align-content: flex-start; \n                gap: 3mm; /* Jarak horizontal antar kartu */\n            }\n            \n            .kartu { \n                width: 10.08cm; \n                height: 8.78cm; \n                border: 2px solid #000; \n                outline: 1px dashed #999; \n                outline-offset: 1mm; /* Garis gunting dirapatkan agar muat */\n                box-sizing: border-box;\n                margin: 0; /* Hapus margin bawaan */\n                margin-bottom: 5mm; /* Jarak vertikal ke kartu bawahnya */\n                page-break-inside: avoid; /* Mencegah kartu terpotong antar halaman */\n            }\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"app-container\" id=\"app-container\">\n    <h2>Sistem Manajemen Ujian Madrasah<\/h2>\n    \n    \n    <div class=\"tab-menu\">\n        <button class=\"tab-btn active\" onclick=\"bukaTab('tab-data', this)\">Daftar Data Peserta<\/button>\n        <button class=\"tab-btn\" onclick=\"bukaTab('tab-pengaturan', this)\">Pengaturan Kop & TTD<\/button>\n        <button class=\"tab-btn\" onclick=\"bukaTab('tab-kartu', this)\">Tampilan Kartu<\/button>\n    <\/div>\n\n    \n    <div id=\"tab-data\" class=\"tab-content active\">\n        \n        <div class=\"toolbar\">\n            <div style=\"display: flex; gap:10px; flex-wrap: wrap;\">\n                <button class=\"btn-toolbar btn-tambah\" onclick=\"bukaModalForm()\">\u2795 Tambah Siswa<\/button>\n                <button class=\"btn-toolbar btn-template\" onclick=\"downloadTemplateExcel()\">\u2b07\ufe0f Download Template Excel<\/button>\n                <button class=\"btn-toolbar btn-excel\" onclick=\"document.getElementById('inputExcel').click()\">\ud83d\udcca Impor dari Excel<\/button>\n                <input type=\"file\" id=\"inputExcel\" accept=\".xlsx, .xls\" style=\"display: none;\" onchange=\"prosesImporExcel(event)\">\n            <\/div>\n            \n        <\/div>\n\n        <div class=\"box-area\">\n            <p style=\"margin-top:0;\"><strong>\ud83d\udcf8 Impor Foto Massal (Deteksi Username)<\/strong><\/p>\n            <input type=\"file\" id=\"inputFoto\" multiple accept=\"image/*\" onchange=\"prosesImporFoto(event)\">\n        <\/div>\n\n        <table>\n            <thead>\n                <tr>\n                    <th>Nama<\/th>\n                    <th>Tgl Lahir<\/th>\n                    <th>No. Ujian<\/th>\n                    <th>Username<\/th>\n                    <th>Password<\/th>\n                    <th style=\"width: 140px; text-align:center;\">Aksi<\/th>\n                <\/tr>\n            <\/thead>\n            <tbody id=\"tabel-body\">\n                \n            <\/tbody>\n        <\/table>\n    <\/div>\n\n    \n    <div id=\"tab-pengaturan\" class=\"tab-content\">\n        <div class=\"box-area\" style=\"background: #fff; border: 1px solid #ccc;\">\n            <h3 style=\"margin-top: 0; border-bottom: 1px solid #eee; padding-bottom: 10px;\">Bagian Kop Surat<\/h3>\n            <div class=\"form-group\"><label>Ganti Logo (Opsional):<\/label><input type=\"file\" accept=\"image/*\" id=\"input-logo\" onchange=\"gantiLogo(event)\"><\/div>\n            <div class=\"form-group\"><label>Teks Baris 1:<\/label><input type=\"text\" id=\"input-kop-1\" value=\"Kartu Peserta\"><\/div>\n            <div class=\"form-group\"><label>Teks Baris 2:<\/label><input type=\"text\" id=\"input-kop-2\" value=\"Ujian Madrasah\"><\/div>\n            <div class=\"form-group\"><label>Teks Baris 3:<\/label><input type=\"text\" id=\"input-kop-3\" value=\"Tahun Pelajaran 2025/2026\"><\/div>\n            <div class=\"form-group\"><label>Teks Baris 4:<\/label><input type=\"text\" id=\"input-kop-4\" value=\"MI Hidayatus Shibyan\"><\/div>\n            \n            <h3 style=\"margin-top: 25px; border-bottom: 1px solid #eee; padding-bottom: 10px;\">Bagian Tanda Tangan<\/h3>\n            <div class=\"form-group\"><label>Tempat & Tanggal Kartu:<\/label><input type=\"text\" id=\"input-tgl-surat\" value=\"Lamongan, 01 Mei 2026\"><\/div>\n            \n            <div class=\"form-group\">\n                <label>Upload Tanda Tangan (Opsional):<\/label>\n                <input type=\"file\" accept=\"image/*\" id=\"input-ttd\" onchange=\"gantiTTD(event)\">\n                <p style=\"font-size: 11px; color: #777; margin-top: 4px;\">*Mendukung format JPG/PNG. Jika dikosongkan, area tanda tangan akan tetap kosong untuk ditandatangani manual.<\/p>\n            <\/div>\n            \n            <div class=\"form-group\"><label>Nama Kepala Madrasah:<\/label><input type=\"text\" id=\"input-nama-kepsek\" value=\"IMAM TAUFIQ, ST\"><\/div>\n\n            <button class=\"btn-simpan\" onclick=\"terapkanKop()\" style=\"margin-top: 15px; width: 100%;\">Terapkan Perubahan<\/button>\n        <\/div>\n    <\/div>\n\n    \n    <div id=\"tab-kartu\" class=\"tab-content\">\n        \n        \n        <div style=\"display: flex; gap: 10px; margin-bottom: 15px;\">\n            <button onclick=\"cetakKartuSatu()\" style=\"padding: 10px 15px; background: #ff9800; border: none; color: white; cursor: pointer; border-radius: 4px; font-weight: bold;\">\ud83d\udda8\ufe0f Cetak Kartu Ini Saja<\/button>\n            <button onclick=\"cetakSemuaF4()\" style=\"padding: 10px 15px; background: #E91E63; border: none; color: white; cursor: pointer; border-radius: 4px; font-weight: bold;\">\ud83d\udda8\ufe0f Cetak Semua Data (Kertas F4)<\/button>\n        <\/div>\n        \n        <div class=\"kartu-wrapper\">\n            <div class=\"kartu\" id=\"kartu-preview\">\n                <div class=\"header\">\n                    <img id=\"img-logo-kop\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/Logo_Kementerian_Agama_Republik_Indonesia.svg/200px-Logo_Kementerian_Agama_Republik_Indonesia.svg.png\" alt=\"Logo\" class=\"logo\">\n                    <div class=\"header-text\">\n                        <p id=\"teks-kop-1\" class=\"teks-1\">Kartu Peserta<\/p>\n                        <p id=\"teks-kop-2\" class=\"teks-2\">Ujian Madrasah<\/p>\n                        <p id=\"teks-kop-3\" class=\"teks-3\">Tahun Pelajaran 2025/2026<\/p>\n                        <p id=\"teks-kop-4\" class=\"teks-4\">MI Hidayatus Shibyan<\/p>\n                    <\/div>\n                <\/div>\n                <table class=\"info-table\">\n                    <tr><td>No. Peserta<\/td><td>:<\/td><td id=\"k-no\">...<\/td><\/tr>\n                    <tr><td>Nama<\/td><td>:<\/td><td><strong id=\"k-nama\">...<\/strong><\/td><\/tr>\n                    <tr><td>Tanggal Lahir<\/td><td>:<\/td><td id=\"k-tgl\">...<\/td><\/tr>\n                    <tr><td>Username<\/td><td>:<\/td><td id=\"k-user\">...<\/td><\/tr>\n                    <tr><td>Password<\/td><td>:<\/td><td id=\"k-pass\">...<\/td><\/tr>\n                <\/table>\n                <div class=\"footer\">\n                    <div class=\"photo-box\" id=\"k-foto-box\"><span style=\"font-size: 10px; color: #888;\">Foto<\/span><\/div>\n                    <div class=\"signature\">\n                        <p id=\"k-tgl-surat\">Lamongan, 01 Mei 2026<\/p>\n                        <p>Kepala Madrasah<\/p>\n                        \n                        <div class=\"ttd-box-area\">\n                            <img id=\"img-ttd-preview\" src=\"\" alt=\"TTD\">\n                        <\/div>\n                        \n                        <p class=\"name\" id=\"k-kepsek\">IMAM TAUFIQ, ST<\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n\n\n<div id=\"modalForm\" class=\"modal\">\n    <div class=\"modal-content\">\n        <div class=\"modal-header\">\n            <span id=\"modal-judul\">Tambah Siswa<\/span>\n            <span class=\"close-btn\" onclick=\"tutupModalForm()\">&times;<\/span>\n        <\/div>\n        <input type=\"hidden\" id=\"form-index\" value=\"\"> \n        <div class=\"form-group\"><label>Nama Peserta:<\/label><input type=\"text\" id=\"form-nama\" autocomplete=\"off\"><\/div>\n        <div class=\"form-group\"><label>Tanggal Lahir:<\/label><input type=\"text\" id=\"form-tgl\" placeholder=\"Contoh: 2006-03-08\" autocomplete=\"off\"><\/div>\n        <div class=\"form-group\"><label>Nomor Ujian:<\/label><input type=\"text\" id=\"form-no\" autocomplete=\"off\"><\/div>\n        <div class=\"form-group\"><label>Username:<\/label><input type=\"text\" id=\"form-user\" autocomplete=\"off\"><\/div>\n        <div class=\"form-group\"><label>Password:<\/label><input type=\"text\" id=\"form-pass\" autocomplete=\"off\"><\/div>\n        <div class=\"modal-footer\">\n            <button class=\"btn-batal\" onclick=\"tutupModalForm()\">Batal<\/button>\n            <button class=\"btn-simpan\" onclick=\"simpanSiswa()\">Simpan Data<\/button>\n        <\/div>\n    <\/div>\n<\/div>\n\n\n<div id=\"area-cetak\"><\/div>\n\n<script>\n    // --- DATA PESERTA AWAL ---\n    let dataPeserta = [\n        { nama: \"AFZAN MAULIDU ANAQIE\", tglLahir: \"2006-03-08\", noUjian: \"26-13-18-1-0167-0003\", username: \"131203\", password: \"131203\", fotoUrl: \"\" }\n    ];\n    \n    // Variabel Global untuk menyimpan gambar TTD\n    let ttdGlobalSrc = \"\";\n\n    function renderTabel() {\n        const tbody = document.getElementById(\"tabel-body\");\n        tbody.innerHTML = \"\";\n        dataPeserta.forEach((p, index) => {\n            const tr = `<tr>\n                <td>${p.nama} ${p.fotoUrl ? '\u2705' : ''}<\/td>\n                <td>${p.tglLahir}<\/td>\n                <td>${p.noUjian}<\/td>\n                <td>${p.username}<\/td>\n                <td>${p.password}<\/td>\n                <td style=\"text-align:center;\">\n                    <button class=\"btn-lihat\" onclick=\"lihatKartu(${index})\" title=\"Preview Kartu\">\ud83d\udc41\ufe0f<\/button>\n                    <button class=\"btn-edit\" onclick=\"bukaModalForm(${index})\" title=\"Edit Data\">\u270f\ufe0f<\/button>\n                    <button class=\"btn-hapus\" onclick=\"hapusSiswa(${index})\" title=\"Hapus Data\">\ud83d\uddd1\ufe0f<\/button>\n                <\/td>\n            <\/tr>`;\n            tbody.innerHTML += tr;\n        });\n    }\n\n    // CRUD Siswa\n    function bukaModalForm(index = null) {\n        document.getElementById('modalForm').style.display = 'block';\n        if(index !== null) {\n            document.getElementById('modal-judul').innerText = \"Edit Siswa\";\n            document.getElementById('form-index').value = index;\n            document.getElementById('form-nama').value = dataPeserta[index].nama;\n            document.getElementById('form-tgl').value = dataPeserta[index].tglLahir;\n            document.getElementById('form-no').value = dataPeserta[index].noUjian;\n            document.getElementById('form-user').value = dataPeserta[index].username;\n            document.getElementById('form-pass').value = dataPeserta[index].password;\n        } else {\n            document.getElementById('modal-judul').innerText = \"Tambah Siswa Baru\";\n            document.getElementById('form-index').value = \"\";\n            document.getElementById('form-nama').value = \"\";\n            document.getElementById('form-tgl').value = \"\";\n            document.getElementById('form-no').value = \"\";\n            document.getElementById('form-user').value = \"\";\n            document.getElementById('form-pass').value = \"\";\n        }\n    }\n\n    function tutupModalForm() { document.getElementById('modalForm').style.display = 'none'; }\n\n    function simpanSiswa() {\n        const index = document.getElementById('form-index').value;\n        const dataBaru = {\n            nama: document.getElementById('form-nama').value.toUpperCase(),\n            tglLahir: document.getElementById('form-tgl').value,\n            noUjian: document.getElementById('form-no').value,\n            username: document.getElementById('form-user').value,\n            password: document.getElementById('form-pass').value,\n            fotoUrl: \"\" \n        };\n\n        if(dataBaru.nama === \"\" || dataBaru.username === \"\") { alert(\"Nama dan Username tidak boleh kosong!\"); return; }\n\n        if(index === \"\") dataPeserta.push(dataBaru); \n        else {\n            dataBaru.fotoUrl = dataPeserta[index].fotoUrl; \n            dataPeserta[index] = dataBaru;\n        }\n        tutupModalForm(); renderTabel();\n    }\n\n    function hapusSiswa(index) {\n        if(confirm(`Yakin ingin menghapus data ${dataPeserta[index].nama}?`)) {\n            dataPeserta.splice(index, 1); renderTabel();\n        }\n    }\n\n    // --- FUNGSI DOWNLOAD TEMPLATE EXCEL ---\n    function downloadTemplateExcel() {\n        const dataTemplate = [\n            [\"Nama\", \"Tgl Lahir\", \"No. Ujian\", \"Username\", \"Password\"],\n            [\"CONTOH NAMA SISWA\", \"2006-03-08\", \"26-13-18-1-0167-0003\", \"131203\", \"131203\"]\n        ];\n\n        const workbook = XLSX.utils.book_new();\n        const worksheet = XLSX.utils.aoa_to_sheet(dataTemplate);\n        worksheet['!cols'] = [ { wch: 30 }, { wch: 15 }, { wch: 25 }, { wch: 15 }, { wch: 15 } ];\n        \n        XLSX.utils.book_append_sheet(workbook, worksheet, \"Data_Siswa\");\n        XLSX.writeFile(workbook, \"Template_Data_Siswa.xlsx\");\n    }\n\n    // --- FUNGSI IMPOR EXCEL ---\n    function prosesImporExcel(event) {\n        const file = event.target.files[0];\n        if(!file) return;\n\n        const reader = new FileReader();\n        reader.onload = function(e) {\n            const data = new Uint8Array(e.target.result);\n            const workbook = XLSX.read(data, {type: 'array'});\n            const firstSheetName = workbook.SheetNames[0];\n            const worksheet = workbook.Sheets[firstSheetName];\n            const jsonSheet = XLSX.utils.sheet_to_json(worksheet, {raw: false});\n            let berhasil = 0;\n\n            jsonSheet.forEach(row => {\n                const keys = Object.keys(row);\n                const getVal = (keywords) => {\n                    const matchKey = keys.find(k => {\n                        const kLower = k.toLowerCase();\n                        return keywords.some(word => kLower.includes(word));\n                    });\n                    return matchKey ? row[matchKey] : \"\";\n                };\n\n                const nama = getVal([\"nama\"]);\n                const tgl = getVal([\"lahir\", \"tanggal\", \"tgl\", \"ttl\"]); \n                const no = getVal([\"ujian\", \"nomor\", \"peserta\", \"no. \", \"no \"]);\n                const user = getVal([\"user\"]);\n                const pass = getVal([\"pass\"]);\n\n                if(nama && user) { \n                    dataPeserta.push({\n                        nama: nama.toUpperCase(), tglLahir: tgl, noUjian: no, username: user, password: pass, fotoUrl: \"\"\n                    });\n                    berhasil++;\n                }\n            });\n\n            alert(`Selesai! Berhasil mengimpor ${berhasil} data siswa dari Excel.`);\n            renderTabel();\n            document.getElementById('inputExcel').value = \"\"; \n        };\n        reader.readAsArrayBuffer(file);\n    }\n\n    // Navigasi & Setup Kartu\n    function bukaTab(tabId, btnElement) {\n        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));\n        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));\n        document.getElementById(tabId).classList.add('active');\n        if(btnElement) btnElement.classList.add('active');\n        else document.querySelectorAll('.tab-btn')[['tab-data', 'tab-pengaturan', 'tab-kartu'].indexOf(tabId)].classList.add('active');\n    }\n\n    function lihatKartu(index) {\n        const p = dataPeserta[index];\n        document.getElementById('k-no').innerText = p.noUjian;\n        document.getElementById('k-nama').innerText = p.nama;\n        document.getElementById('k-tgl').innerText = p.tglLahir;\n        document.getElementById('k-user').innerText = p.username;\n        document.getElementById('k-pass').innerText = p.password;\n        const fotoBox = document.getElementById('k-foto-box');\n        if(p.fotoUrl) fotoBox.innerHTML = `<img src=\"${p.fotoUrl}\">`;\n        else fotoBox.innerHTML = `<span style=\"font-size: 10px; color: #888;\">Foto<\/span>`;\n        bukaTab('tab-kartu');\n    }\n\n    function prosesImporFoto(event) {\n        const files = event.target.files;\n        if(files.length === 0) return;\n        let fotoCocok = 0;\n        for(let i = 0; i < files.length; i++) {\n            const file = files[i];\n            const namaFileTanpaEkstensi = file.name.split('.').slice(0, -1).join('.');\n            const indexPeserta = dataPeserta.findIndex(p => p.username === namaFileTanpaEkstensi);\n            if(indexPeserta !== -1) {\n                dataPeserta[indexPeserta].fotoUrl = URL.createObjectURL(file);\n                fotoCocok++;\n            }\n        }\n        alert(`${fotoCocok} foto berhasil dicocokkan!`); renderTabel();\n    }\n\n    // --- LOGIKA TERAPKAN PENGATURAN (TERMASUK TTD) ---\n    function terapkanKop() {\n        document.getElementById('teks-kop-1').innerText = document.getElementById('input-kop-1').value;\n        document.getElementById('teks-kop-2').innerText = document.getElementById('input-kop-2').value;\n        document.getElementById('teks-kop-3').innerText = document.getElementById('input-kop-3').value;\n        document.getElementById('teks-kop-4').innerText = document.getElementById('input-kop-4').value;\n        document.getElementById('k-tgl-surat').innerText = document.getElementById('input-tgl-surat').value;\n        document.getElementById('k-kepsek').innerText = document.getElementById('input-nama-kepsek').value;\n        alert(\"Pengaturan Kop dan Tanda Tangan berhasil diperbarui!\"); bukaTab('tab-kartu');\n    }\n    \n    function gantiLogo(event) {\n        if(event.target.files[0]) document.getElementById('img-logo-kop').src = URL.createObjectURL(event.target.files[0]);\n    }\n\n    function gantiTTD(event) {\n        if(event.target.files[0]) {\n            ttdGlobalSrc = URL.createObjectURL(event.target.files[0]);\n            const imgTtdPreview = document.getElementById('img-ttd-preview');\n            imgTtdPreview.src = ttdGlobalSrc;\n            imgTtdPreview.style.display = 'block'; \n        }\n    }\n\n    // --- LOGIKA CETAK ---\n    function cetakKartuSatu() {\n        const areaCetak = document.getElementById('area-cetak');\n        areaCetak.innerHTML = document.getElementById('kartu-preview').outerHTML;\n        window.print();\n    }\n\n    function cetakSemuaF4() {\n        const areaCetak = document.getElementById('area-cetak');\n        areaCetak.innerHTML = ''; \n        \n        const logoSrc = document.getElementById('img-logo-kop').src;\n        const t1 = document.getElementById('teks-kop-1').innerText;\n        const t2 = document.getElementById('teks-kop-2').innerText;\n        const t3 = document.getElementById('teks-kop-3').innerText;\n        const t4 = document.getElementById('teks-kop-4').innerText;\n        const tglSurat = document.getElementById('k-tgl-surat').innerText;\n        const kepsek = document.getElementById('k-kepsek').innerText;\n        \n        const elemenTtd = ttdGlobalSrc ? `<img src=\"${ttdGlobalSrc}\" style=\"display:block;\">` : ``;\n\n        dataPeserta.forEach(p => {\n            let fotoHTML = p.fotoUrl ? `<img src=\"${p.fotoUrl}\">` : `<span style=\"font-size: 10px; color: #888;\">Foto<\/span>`;\n            let cardHTML = `\n            <div class=\"kartu\">\n                <div class=\"header\">\n                    <img src=\"${logoSrc}\" class=\"logo\">\n                    <div class=\"header-text\"><p class=\"teks-1\">${t1}<\/p><p class=\"teks-2\">${t2}<\/p><p class=\"teks-3\">${t3}<\/p><p class=\"teks-4\">${t4}<\/p><\/div>\n                <\/div>\n                <table class=\"info-table\">\n                    <tr><td>No. Peserta<\/td><td>:<\/td><td>${p.noUjian}<\/td><\/tr>\n                    <tr><td>Nama<\/td><td>:<\/td><td><strong>${p.nama}<\/strong><\/td><\/tr>\n                    <tr><td>Tanggal Lahir<\/td><td>:<\/td><td>${p.tglLahir}<\/td><\/tr>\n                    <tr><td>Username<\/td><td>:<\/td><td>${p.username}<\/td><\/tr>\n                    <tr><td>Password<\/td><td>:<\/td><td>${p.password}<\/td><\/tr>\n                <\/table>\n                <div class=\"footer\">\n                    <div class=\"photo-box\">${fotoHTML}<\/div>\n                    <div class=\"signature\">\n                        <p>${tglSurat}<\/p>\n                        <p>Kepala Madrasah<\/p>\n                        <div class=\"ttd-box-area\">${elemenTtd}<\/div>\n                        <p class=\"name\">${kepsek}<\/p>\n                    <\/div>\n                <\/div>\n            <\/div>`;\n            areaCetak.innerHTML += cardHTML;\n        });\n        window.print();\n    }\n\n    window.onload = renderTabel;\n<\/script>\n\n<\/body>\n<\/html>"
}